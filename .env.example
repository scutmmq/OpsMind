# OpsMind 环境变量模板 — 复制为 .env 后修改
# 16GB 内存配置

# ============================================
# 数据库（PostgreSQL 容器 + OpsMind 服务端共用）
# ============================================
POSTGRES_DB=opsmind
POSTGRES_USER=opsmind
POSTGRES_PASSWORD=opsmind_dev

# OpsMind 服务端连接 PostgreSQL（容器内通过 service name "postgres"）
OPSMIND_DATABASE_HOST=postgres
OPSMIND_DATABASE_PORT=5432
OPSMIND_DATABASE_USER=opsmind
OPSMIND_DATABASE_PASSWORD=opsmind_dev
OPSMIND_DATABASE_NAME=opsmind
OPSMIND_DATABASE_SSLMODE=disable

# ============================================
# MinIO 对象存储
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
OPSMIND_MINIO_ENDPOINT=minio:9000
OPSMIND_MINIO_ACCESS_KEY=minioadmin
OPSMIND_MINIO_SECRET_KEY=minioadmin
OPSMIND_MINIO_USE_SSL=false

# ============================================
# JWT
# ============================================
OPSMIND_JWT_SECRET=change_me_to_random_64_chars
OPSMIND_JWT_ACCESS_EXPIRE=2h
OPSMIND_JWT_REFRESH_EXPIRE=168h

# ============================================
# 服务基础配置
# ============================================
OPSMIND_SERVER_PORT=8080
OPSMIND_SERVER_MODE=debug

# ============================================
# LLM（llama.cpp server，需 --profile ai-local）
# ============================================
OPSMIND_LLM_BASE_URL=http://llama-cpp:8080/v1
OPSMIND_LLM_API_KEY=
OPSMIND_LLM_MODEL=Qwen3-4B-Q4_K_M
OPSMIND_LLM_MAX_TOKENS=8192

# ============================================
# Embedding（llama.cpp server embedding 端点）
# ============================================
OPSMIND_EMBEDDING_BASE_URL=http://llama-cpp-emb:8080/v1
OPSMIND_EMBEDDING_API_KEY=
OPSMIND_EMBEDDING_MODEL=Qwen3-Embedding-0.6B-Q8_0
OPSMIND_EMBEDDING_DIMENSION=1024

# ============================================
# AI / RAG 管道选项
# ============================================
OPSMIND_AI_DEFAULT_TOP_K=5
OPSMIND_AI_CONFIDENCE_THRESHOLD=0.6
OPSMIND_AI_MAX_HISTORY_MESSAGES=10
OPSMIND_AI_RAG_QUERY_REWRITE=true
OPSMIND_AI_RAG_MULTI_ROUTE=true
OPSMIND_AI_RAG_HYBRID=true
OPSMIND_AI_RAG_RERANK=true

# ============================================
# 重排序（需先下载模型: cd server && python models/rerank/download.py）
# 模型文件内置在 Docker 镜像中，构建后无需网络
# ============================================
OPSMIND_RERANK_ENABLED=true

# ============================================
# CORS — debug 模式自动允许所有 Origin（AllowOriginFunc）
# 生产模式必须在此配置具体域名（逗号分隔）
# ============================================
OPSMIND_CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# 模型目录（仅 ai-local profile 使用）
# ============================================
LLAMA_MODELS_DIR=./models
