# OpsMind 本地开发环境变量模板
#
# 复制此文件为 .env 并根据环境修改：
#   cp .env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到版本库。
#
# ============================================================
# 快速开始:
#   1. cp .env.example .env
#   2. 设置 OPSMIND_JWT_SECRET（必填）
#   3. 选择 LLM 提供商方案（见下方 LLM 配置区）
#   4. docker compose up -d --build
#   5. (可选) 下载模型: make model-download
#   6. (可选) docker compose --profile ai-local up -d llama-cpp
# ============================================================

# ======================================================================
# Docker 服务配置（供 PostgreSQL/MinIO/llama.cpp 容器直接使用，非 OpsMind 后端配置）
# ======================================================================
POSTGRES_PASSWORD=opsmind_dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
LLAMA_MODELS_DIR=./models

# ======================================================================
# 以下 OPSMIND_* 变量对应 server/internal/config/config.yaml 中的配置项。
# 按 config.yaml 分区排列，未显式设置的字段使用 config.yaml 中的默认值。
# 取消注释即可覆盖默认值；本地开发通常保留默认值即可。
# ======================================================================

# ===== Server =====
# OPSMIND_SERVER_PORT=8080
# OPSMIND_SERVER_MODE=debug

# ===== Database =====
# OPSMIND_DATABASE_HOST=localhost
# OPSMIND_DATABASE_PORT=5432
# OPSMIND_DATABASE_USER=opsmind
# OPSMIND_DATABASE_PASSWORD=opsmind_dev
# OPSMIND_DATABASE_DBNAME=opsmind
# OPSMIND_DATABASE_SSLMODE=disable

# ===== JWT =====
# 生产部署必须修改为随机强密码（32 字符以上）
OPSMIND_JWT_SECRET=change-me-to-a-random-string-32-chars
# OPSMIND_JWT_ACCESS_EXPIRE=2h
# OPSMIND_JWT_REFRESH_EXPIRE=168h

# ===== MinIO =====
# OPSMIND_MINIO_ENDPOINT=localhost:9000
# OPSMIND_MINIO_ACCESS_KEY=minioadmin
# OPSMIND_MINIO_SECRET_KEY=minioadmin
# OPSMIND_MINIO_USE_SSL=false

# ===== LLM（支持任意 OpenAI-compatible API）=====
# 方案 A — 本地 llama.cpp（推荐，完全本地化）
# 需要下载 .gguf 模型文件到 ./models 目录。
# 启动命令: docker compose --profile ai-local up -d --build
OPSMIND_LLM_BASE_URL=http://llama-cpp:8080/v1
OPSMIND_LLM_API_KEY=
OPSMIND_LLM_MODEL=qwen3-4b
OPSMIND_LLM_MAX_TOKENS=8192
# 方案 B — OpenAI-compatible API（取消注释并修改为实际值）
# OPSMIND_LLM_BASE_URL=https://api.openai.com/v1
# OPSMIND_LLM_API_KEY=sk-your-api-key
# OPSMIND_LLM_MODEL=gpt-4o-mini
# OPSMIND_LLM_MAX_TOKENS=16384

# ===== Embedding =====
# LLM 和 Embedding 各自拥有独立的 Base URL 和 API Key（空则回退到 LLM 对应配置）。
# 支持跨服务商组合：如 DeepSeek LLM + Moonshot Embedding。
# OPSMIND_EMBEDDING_BASE_URL=
# OPSMIND_EMBEDDING_API_KEY=
OPSMIND_EMBEDDING_MODEL=bge-m3
OPSMIND_EMBEDDING_DIMENSION=1024

# ===== AI（RAG 参数）=====
# OPSMIND_AI_DEFAULT_TOP_K=5
# OPSMIND_AI_CONFIDENCE_THRESHOLD=0.6

# ===== CORS（前端跨域）=====
# OPSMIND_CORS_ALLOW_ORIGINS=http://localhost:5173

# ===== 日志 =====
# OPSMIND_LOG_DIR 指定日志文件输出目录（非 config.yaml 字段，main.go 直接读取）。
# 本地开发默认 ../logs → 项目根目录下的 logs/。
# Docker Compose 覆盖为 ./logs（容器内相对路径）。
# OPSMIND_LOG_DIR=../logs
