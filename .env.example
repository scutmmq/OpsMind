# OpsMind 本地开发环境变量模板
#
# 复制此文件为 .env 并根据环境修改：
#   cp .env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到版本库。
#
# ============================================================
# 快速开始:
#   1. cp .env.example .env
#   2. 设置 OPSMIND_JWT_SECRET（必填）
#   3. *** 选择 LLM 提供商并填写对应配置（见下方 LLM 配置区）***
#   4. docker compose up -d --build
#   5. (可选) 下载模型: make model-download
#   6. (可选) 配置 AnythingLLM API Key
# ============================================================

# ===== PostgreSQL =====
POSTGRES_PASSWORD=opsmind_dev

# ===== MinIO 对象存储 =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== OpsMind 后端 =====
# 生产部署必须修改为随机强密码（32 字符以上）
OPSMIND_JWT_SECRET=change-me-to-a-random-string-32-chars

# ===== AnythingLLM 内部组件 =====
# AnythingLLM 地址（Docker 内部使用服务名 anythingllm，无需修改）
ANYTHINGLLM_BASE_URL=http://anythingllm:3001/api
# ⚠️ 部署后必须通过管理页面创建 API Key 并填入此处：
#    1. 取消 docker-compose.yml 中 anythingllm 的 ports 注释
#    2. docker compose up -d anythingllm
#    3. 浏览器访问 http://localhost:3001 → 完成初始化向导
#    4. Settings → API Keys → 创建 Key → 填入下方
ANYTHINGLLM_API_KEY=replace-after-create-api-key
ANYTHINGLLM_JWT_SECRET=replace-with-random-string-20-plus
ANYTHINGLLM_SIG_KEY=replace-with-random-string-32-plus
ANYTHINGLLM_SIG_SALT=replace-with-random-string-32-plus

# ======================================================================
# LLM 配置（选择下面一种方案，注释掉其余）
# ======================================================================
# AnythingLLM 通过 generic-openai 提供商对接所有 OpenAI 兼容 API。
# 根据需要选择本地部署（vLLM/Ollama）或云服务（OpenAI/DeepSeek 等）。

# ----- 方案 A：本地 vLLM（推荐，数据不出域）-----
# 需要先下载模型: make model-download
# 启动命令: docker compose --profile ai-local up -d --build
LLM_BASE_URL=http://vllm:8000/v1
LLM_MODEL=qwen3-4b
LLM_TOKEN_LIMIT=8192
LLM_API_KEY=dummy-key

# ----- 方案 B：OpenAI 官方 API（最简单，按量付费）-----
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_TOKEN_LIMIT=16384
# LLM_API_KEY=sk-your-openai-api-key

# ----- 方案 C：本地 Ollama（轻量级，无需 GPU）-----
# 需要先安装 Ollama 并拉取模型: ollama pull qwen2.5:7b
# 注意：Docker 内部访问宿主机用 host.docker.internal
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=qwen2.5:7b
# LLM_TOKEN_LIMIT=8192
# LLM_API_KEY=dummy-key

# ----- 方案 D：其他 OpenAI 兼容服务（DeepSeek/Moonshot/等）-----
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_TOKEN_LIMIT=16384
# LLM_API_KEY=sk-your-deepseek-api-key

# ======================================================================
# Embedding 配置
# ======================================================================
# Embedding 服务同样使用 OpenAI 兼容 API，本地 vLLM 或云服务均可。
# 本地 vLLM 部署需要下载 BGE-M3 模型:
#   modelscope download --model BAAI/bge-m3 --local_dir ./models/bge-m3
EMBEDDING_BASE_URL=http://vllm:8000/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_MAX_CHUNK_LENGTH=8192
EMBEDDING_API_KEY=dummy-key

# 如果使用 OpenAI 的 Embedding:
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-your-openai-api-key
