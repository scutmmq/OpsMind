# OpsMind 环境变量配置模板
#
# 复制此文件为 .env 并填写实际值：
#   cp .env.example .env
#
# .env 已被 .gitignore 忽略，不会提交到版本库。

# ── PostgreSQL ──────────────────────────────────
POSTGRES_USER=opsmind
POSTGRES_PASSWORD=opsmind123
POSTGRES_DB=opsmind

# ── OpsMind 后端 ────────────────────────────────
OPSMIND_DATABASE_HOST=localhost
OPSMIND_DATABASE_PORT=5432
OPSMIND_DATABASE_USER=opsmind
OPSMIND_DATABASE_PASSWORD=opsmind123
OPSMIND_DATABASE_DBNAME=opsmind
OPSMIND_DATABASE_SSLMODE=disable

OPSMIND_JWT_SECRET=change-me-in-production
OPSMIND_SERVER_PORT=8080
OPSMIND_SERVER_MODE=debug

# ── MinIO ───────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
OPSMIND_MINIO_ENDPOINT=localhost:9000
OPSMIND_MINIO_ACCESS_KEY=minioadmin
OPSMIND_MINIO_SECRET_KEY=minioadmin

# ── AnythingLLM ─────────────────────────────────
OPSMIND_ANYTHINGLLM_BASE_URL=http://anythingllm:3001/api
OPSMIND_ANYTHINGLLM_API_KEY=
OPSMIND_ANYTHINGLLM_DEFAULT_WORKSPACE_SLUG=opsmind-it-ops

# ── AI ──────────────────────────────────────────
OPSMIND_AI_DEFAULT_TOP_K=5
OPSMIND_AI_CONFIDENCE_THRESHOLD=0.6
