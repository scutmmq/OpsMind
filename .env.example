# OpsMind 本地开发环境变量模板
#
# 复制此文件为 .env 并根据环境修改：
#   cp .env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到版本库。
#
# ============================================================
# 快速开始:
#   1. cp .env.example .env
#   2. 设置 JWT_SECRET（必填）
#   3. 选择 LLM 提供商方案（见下方 LLM 配置区）
#   4. docker compose up -d --build
#   5. (可选) 下载模型: make model-download
#   6. (可选) docker compose --profile ai-local up -d llama-cpp
# ============================================================

# ===== PostgreSQL + pgvector =====
POSTGRES_PASSWORD=opsmind_dev

# ===== MinIO 对象存储 =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== OpsMind 后端 =====
# 生产部署必须修改为随机强密码（32 字符以上）
JWT_SECRET=change-me-to-a-random-string-32-chars

# ======================================================================
# LLM + Embedding 配置
# ======================================================================
# LLM 和 Embedding 各自拥有独立的 Base URL（空则回退）。
# 提供两种方案，根据需要取消注释并修改：
#   方案 A — 本地 llama.cpp（无需 API Key）
#   方案 B — OpenAI-compatible API（LLM / Embedding 可任意组合服务商）

# ----- 方案 A：本地 llama.cpp（推荐，完全本地化）-----
# 需要下载 .gguf 模型文件到 ./models 目录。
# 启动命令: docker compose --profile ai-local up -d --build
LLM_BASE_URL=http://llama-cpp:8080/v1
LLM_API_KEY=
LLM_MODEL=qwen3-4b
LLM_MAX_TOKENS=8192
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024

# ===== RAG 参数 =====
AI_CONFIDENCE_THRESHOLD=0.6
AI_DEFAULT_TOP_K=5

# ===== llama.cpp 模型目录（仅方案 A 需要）=====
LLAMA_MODELS_DIR=./models

# ----- 方案 B：OpenAI-compatible API（LLM 和 Embedding 可任意组合）-----
# LLM 和 Embedding 的 base_url 可分别指向不同服务商，自由排列即可。
# 以下为参考配置（取消注释并修改为实际值）：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=16384
# EMBEDDING_BASE_URL=          # 留空则复用 LLM_BASE_URL；或指向其他服务
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
