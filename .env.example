# OpsMind 环境变量模板 — 复制为 .env 后修改
# 16GB 内存配置

# === 数据库 ===
POSTGRES_DB=opsmind
POSTGRES_USER=opsmind
POSTGRES_PASSWORD=change_me_in_production

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# === JWT ===
OPSMIND_JWT_SECRET=change_me_to_random_64_chars

# === 模型下载源 ===
# 默认 ModelScope（阿里 CDN），切 HF 改 https://huggingface.co
# MODEL_DOWNLOAD_BASE=https://modelscope.cn/models

# === LLM ===
OPSMIND_LLM_BASE_URL=http://llama-cpp:8080/v1
OPSMIND_LLM_API_KEY=
OPSMIND_LLM_MODEL=Qwen3-4B-Q4_K_M
OPSMIND_LLM_MAX_TOKENS=8192

# === Embedding ===
OPSMIND_EMBEDDING_BASE_URL=http://llama-cpp-emb:8080/v1
OPSMIND_EMBEDDING_API_KEY=
OPSMIND_EMBEDDING_MODEL=Qwen3-Embedding-0.6B-Q8_0
OPSMIND_EMBEDDING_DIMENSION=1024

# === AI / RAG ===
OPSMIND_AI_DEFAULT_TOP_K=5
OPSMIND_AI_CONFIDENCE_THRESHOLD=0.6
OPSMIND_AI_MAX_HISTORY_MESSAGES=10
OPSMIND_AI_RAG_QUERY_REWRITE=true
OPSMIND_AI_RAG_MULTI_ROUTE=true
OPSMIND_AI_RAG_HYBRID=true
OPSMIND_AI_RAG_RERANK=true

# === Rerank（16GB 可开启，提升检索精度 ~5%）===
OPSMIND_RERANK_ENABLED=true

# === CORS ===
OPSMIND_CORS_ALLOW_ORIGINS=http://localhost:5173

# === 模型目录 ===
LLAMA_MODELS_DIR=./models
